# ============================================================
# CoT Harness Engineering — 环境配置文件模板
# ============================================================
# 使用方式:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 根据你的 Notebook 实例修改以下配置
#   3. .env 已加入 .gitignore，不会被提交到 Git
# ============================================================

# --- LLM API 配置 ---
# Notebook 上启动 vLLM 后的 API 地址（默认 localhost）
LLM_API_BASE="http://localhost:8000/v1"
LLM_API_KEY="EMPTY"
LLM_MODEL_NAME="Qwen/Qwen2.5-Coder-7B-Instruct"

# --- 请求参数 ---
LLM_TIMEOUT=300
LLM_MAX_CONCURRENT=4

# --- vLLM / ModelScope 加速（可选）---
# 设为 True 可自动从魔搭社区下载模型，加速国内网络
# VLLM_USE_MODELSCOPE=False
